FROM node:22-alpine

# Install system dependencies (Git, CMake, and linux-headers are required for dependencies)
RUN apk add --no-cache git python3 py3-pip make g++ cmake linux-headers openssl \
    github-cli \
    chromium \
    go

# Install OpenClaw globally
RUN npm install -g openclaw@latest

# Install Playwright MCP (browser automation skill)
RUN npm install -g @playwright/mcp@latest
ENV PLAYWRIGHT_MCP_HEADLESS=true
ENV PLAYWRIGHT_BROWSERS_PATH=/usr/bin
ENV PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium-browser

# Install obsidian-cli (Obsidian vault skill) - module renamed to notesmd-cli
RUN GOPATH=/tmp/go go install github.com/Yakitrak/notesmd-cli@latest && \
    mv /tmp/go/bin/notesmd-cli /usr/local/bin/obsidian-cli && \
    rm -rf /tmp/go

# Install agentmail SDK
RUN pip install --break-system-packages agentmail

# Install ClawdHub CLI (with missing undici dependency)
RUN npm install -g clawdhub undici

# Run as non-root user (node:1000)
USER 1000:1000
WORKDIR /home/node

# Default command (force bind to 0.0.0.0 for container networking)
CMD ["openclaw", "gateway", "--allow-unconfigured", "--bind", "lan"]
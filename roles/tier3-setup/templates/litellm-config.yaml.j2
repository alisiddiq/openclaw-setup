model_list:
{% if llm_provider == 'anthropic' %}
  - model_name: "{{ llm_model }}"
    litellm_params:
      model: "anthropic/{{ llm_model }}"
      api_key: "os.environ/TARGET_LLM_KEY"

  - model_name: "*"
    litellm_params:
      model: "anthropic/{{ llm_model }}"
      api_key: "os.environ/TARGET_LLM_KEY"
{% elif llm_provider == 'openai' %}
  - model_name: "{{ llm_model }}"
    litellm_params:
      model: "openai/{{ llm_model }}"
      api_key: "os.environ/TARGET_LLM_KEY"

  - model_name: "*"
    litellm_params:
      model: "openai/{{ llm_model }}"
      api_key: "os.environ/TARGET_LLM_KEY"
{% else %}
  - model_name: "{{ llm_model }}"
    litellm_params:
      model: "ollama/{{ llm_model }}"
      api_base: "{{ llm_url }}"
      api_key: "os.environ/TARGET_LLM_KEY"

  - model_name: "*"
    litellm_params:
      model: "ollama/{{ llm_model }}"
      api_base: "{{ llm_url }}"
      api_key: "os.environ/TARGET_LLM_KEY"
{% endif %}

general_settings:
  master_key: os.environ/LITELLM_MASTER_KEY
  max_parallel_requests: 10

litellm_settings:
  request_timeout: 600
  drop_params: true
  num_retries: 2
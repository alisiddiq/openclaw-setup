# Generated by Ansible
LITELLM_MASTER_KEY={{ litellm_key }}
# Target LLM Key (User provided)
TARGET_LLM_KEY={{ llm_key }}
# OpenClaw Gateway Token
OPENCLAW_GATEWAY_TOKEN={{ openclaw_token }}
# Route all providers through LiteLLM proxy
ANTHROPIC_API_BASE=http://litellm:4000
ANTHROPIC_API_KEY={{ litellm_key }}
{% if github_token | length > 0 %}
# GitHub Skill
GITHUB_TOKEN={{ github_token }}
{% endif %}
{% if github_user | length > 0 %}
GITHUB_USERNAME={{ github_user }}
{% endif %}
{% if agentmail_key | length > 0 %}
# AgentMail Skill
AGENTMAIL_API_KEY={{ agentmail_key }}
{% endif %}
